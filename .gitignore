bin/
dist/
data/
tmp/
node_modules/
frontend/node_modules/
frontend/dist/
*.env
!.env.example
*.log
.DS_Store
*.swp
*.swo

# Binaries (nrcc-* catches stray local builds: nrcc-final, nrcc-test, nrcc-linux-*, ...)
nrcc
nrcc.exe
nrcc-*

# npm lockfiles are banned — pnpm-only policy (pnpm-lock.yaml is the source of truth)
package-lock.json

# AI agent / IDE tool configs (local environment only)
.claude/
.cline/
.codebuddy/
.continue/
.junie/
.kiro/

# Skill-registry metadata is not tracked: only the canonical root
# .agents/skills/ + skills-lock.json are kept. The local `.atl/` cache and
# the nested `frontend/.agents/` mirror must not be re-introduced.
.atl/
frontend/.agents/
frontend/skills-lock.json

# pnpm content-addressable store created on the host by `pnpm install`
# (root-owned when produced inside the docker dev container — do not track).
.pnpm-store/
frontend/.pnpm-store/

# Pi subagent runtime scratch (per-session, never tracked).
.pi-subagents/
