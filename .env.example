# ─────────────────────────────────────────────────────────────────────────────
# NRCC environment contract (canonical, per-stack)
#
# Two layers, one purpose:
#   1. Bootstrap  → NRCC_*  fixed at container start; changing requires restart.
#   2. Node-RED   → NODE_RED_* consumed by the runtime on every Start().
#
# All bootstrap variables are NRCC-prefixed. Legacy names (ENCRYPTION_KEY,
# CORS_ORIGINS) are accepted as compatibility aliases and emit a one-time
# deprecation warning — migrate before the next minor.
#
# Full contract: docs/configuration/env-contract.md
# Per-stack contract (one Compose stack = one Node-RED): docs/adr/0003-docker-first-one-stack-per-node-red.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Bootstrap: HTTP + storage (restart required) ─────────────────────────────
PORT=3001
DATA_DIR=./data

# ── Bootstrap: secrets (restart required) ────────────────────────────────────
# Override via Docker Secrets / file-based input in production. See env-contract.md.
NRCC_JWT_SECRET=change-me-in-production
NRCC_ENCRYPTION_KEY=change-me-in-production

# ── Bootstrap: CORS (restart required) ───────────────────────────────────────
# Comma-separated origins. Use NRCC_CORS_UNSAFE_WILDCARD=true to force "*"
# (development only — emits a warning at startup).
NRCC_CORS_ORIGINS=*
# NRCC_CORS_UNSAFE_WILDCARD=false
# NRCC_TRUSTED_PROXIES=

# ── Bootstrap: optional behavior ─────────────────────────────────────────────
# Edge mode: resource-safe defaults for Pi/NAS deployments. See ADR 0002.
EDGE_MODE=false
# Disable the bundled Node-RED lifecycle when running NRCC against an
# external Node-RED only. Default true.
# NRCC_MANAGE_NODE_RED=true
# Run the setup wizard non-interactively (e.g. CI provisioning).
# NRCC_BOOTSTRAP_INTERACTIVE=false

# ── Node-RED runtime (honored by ProcessManager; see #429) ──────────────────
NODE_RED_CMD=node-red
NODE_RED_PORT=1880
# NODE_RED_USER_DIR=/data
# NODE_RED_SETTINGS=/data/settings.js

# ── Optional: AI assistant (off by default) ──────────────────────────────────
# NRCC_AI_ENABLED=false
# NRCC_AI_PROVIDER=openai
# NRCC_AI_ENDPOINT=https://api.openai.com/v1
# NRCC_AI_MODEL=gpt-4o-mini
# NRCC_AI_API_KEY=