# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
# Exception: local dev build needs pre-compiled linux binary
!dist/nrcc-linux-amd64
nrcc
nrcc-*
*.exe

# ── Frontend dev artifacts ────────────────────────────────────────────────────
# node_modules excluded — Docker stages install their own deps
frontend/node_modules/
# frontend/dist excluded so the go-builder stage always picks up the freshly
# pnpm-built bundle from the builder stage (line 21 of the Dockerfile) and the
# `COPY . .` on line 22 does not silently overwrite it with a stale host build.
# If you ever need to embed a pre-built dist from the host, delete this line.
# See issue #459 for context and repro recipe.
frontend/dist/

# ── Test & dev data ───────────────────────────────────────────────────────────
data/
*.log
*.env
.env*

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Docs ──────────────────────────────────────────────────────────────────────
*.md
LICENSE
docs/
