# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.dev — development image
#
# Includes: Node.js 26 + node-red + Go 1.25 + air (hot reload)
# Source code is mounted at runtime — nothing embedded here.
#
# Built once with: docker compose -f docker-compose.dev.yml build
# ─────────────────────────────────────────────────────────────────────────────
FROM node:26

# ── Install Go ────────────────────────────────────────────────────────────────
# Keep in sync with go.mod, CI, and scripts/dev-entrypoint.sh.
ARG GO_VERSION=1.25.11
RUN apt-get update && apt-get install -y --no-install-recommends \
        wget ca-certificates git \
    && wget -qO /tmp/go.tar.gz "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" \
    && tar -C /usr/local -xzf /tmp/go.tar.gz \
    && rm /tmp/go.tar.gz \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

ENV PATH="/usr/local/go/bin:/root/go/bin:${PATH}"
ENV GOPATH="/root/go"

# ── Install node-red globally ─────────────────────────────────────────────────
RUN npm install -g --unsafe-perm node-red && npm cache clean --force

# ── Install air (Go hot reload) ───────────────────────────────────────────────
RUN go install github.com/air-verse/air@latest

# ── Working dir (source mounted at runtime) ───────────────────────────────────
WORKDIR /workspace

ENV DATA_DIR=/data \
    NODE_RED_CMD=node-red \
    PORT=3001

EXPOSE 3001 1880

CMD ["air", "-c", ".air.toml"]
